// WHAI Intelligence Hub — Prisma Schema
// PostgreSQL on Supabase (production) / SQLite for local dev

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
// CORE ENTITIES
// ─────────────────────────────────────────────────────────────────────────────

model Company {
  id                        String   @id @default(cuid())
  name                      String
  legalName                 String?
  website                   String?
  description               String?  @db.Text
  companyType               String?
  ownershipStatus           String?
  foundedYear               Int?
  employeeCountRange        String?
  annualRevenueRange        String?
  headquartersCountry       String?
  headquartersCity          String?
  headquartersStateProvince String?
  stockTicker               String?
  stockExchange             String?
  tags                      String?
  engagementScore           Int?
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  contacts             Contact[]
  verticals            CompanyVertical[]
  therapeuticAreas     CompanyTherapeuticArea[]
  dealsAsTarget        Deal[]         @relation("TargetCompany")
  dealsAsAcquirer      Deal[]         @relation("AcquirerCompany")
  dealInvestments      DealInvestor[]
}

model Contact {
  id              String   @id @default(cuid())
  firstName       String?
  lastName        String?
  email           String?  @unique
  phone           String?
  linkedinUrl     String?
  jobTitle        String?
  seniority       String?
  department      String?
  companyName     String?
  company         Company? @relation(fields: [companyId], references: [id])
  companyId       String?
  country         String?
  city            String?
  stateProvince   String?
  bio             String?  @db.Text
  tags            String?
  engagementScore Int?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Deal {
  id                String    @id @default(cuid())
  title             String
  dealType          String?
  dealStage         String?
  dealValueUsd      BigInt?
  announcedDate     DateTime?
  closedDate        DateTime?
  acquirerCompany   Company?  @relation("AcquirerCompany", fields: [acquirerCompanyId], references: [id])
  acquirerCompanyId String?
  targetCompany     Company?  @relation("TargetCompany", fields: [targetCompanyId], references: [id])
  targetCompanyId   String?
  description       String?   @db.Text
  sourceUrl         String?
  tags              String?
  createdAt         DateTime  @default(now())

  investors DealInvestor[]
}

model DealInvestor {
  id                  String   @id @default(cuid())
  dealId              String
  deal                Deal     @relation(fields: [dealId], references: [id])
  investorCompanyName String?
  investorCompany     Company? @relation(fields: [investorCompanyId], references: [id])
  investorCompanyId   String?
  investorRole        String?
  investmentAmountUsd BigInt?
}

model CompanyVertical {
  id           String  @id @default(cuid())
  companyId    String
  company      Company @relation(fields: [companyId], references: [id])
  verticalSlug String
  isPrimary    Boolean @default(false)

  @@unique([companyId, verticalSlug])
}

model CompanyTherapeuticArea {
  id              String  @id @default(cuid())
  companyId       String
  company         Company @relation(fields: [companyId], references: [id])
  therapeuticArea String

  @@unique([companyId, therapeuticArea])
}

model Insight {
  id          String    @id @default(cuid())
  title       String
  contentType String?
  summary     String?   @db.Text
  body        String?   @db.Text
  author      String?
  publishedAt DateTime?
  isPremium   Boolean   @default(false)
  tags        String?
  createdAt   DateTime  @default(now())
}
