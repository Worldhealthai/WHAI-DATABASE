// WHAI CRM — Prisma Schema
// PostgreSQL on Supabase

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
// DELEGATES — event attendees
// ─────────────────────────────────────────────────────────────────────────────

model Delegate {
  id                   String   @id @default(cuid())
  firstName            String
  lastName             String
  email                String?  @unique
  phone                String?
  linkedinUrl          String?
  organization         String?
  jobTitle             String?
  country              String?
  city                 String?
  // CRM fields
  status               String   @default("Registered")
  event                String?
  subType              String?
  ticketType           String?
  dietaryRequirements  String?
  accessibilityNeeds   String?
  source               String?
  bio                  String?  @db.Text
  tags                 String?
  notes                String?  @db.Text
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  activities Activity[]
}

// ─────────────────────────────────────────────────────────────────────────────
// SPEAKERS — event speakers
// ─────────────────────────────────────────────────────────────────────────────

model Speaker {
  id                 String   @id @default(cuid())
  firstName          String
  lastName           String
  email              String?  @unique
  phone              String?
  linkedinUrl        String?
  organization       String?
  jobTitle           String?
  country            String?
  city               String?
  headshotUrl        String?
  bio                String?  @db.Text
  expertiseAreas     String?
  // CRM fields
  status             String   @default("Prospecting")
  event              String?
  subType            String?
  sessionTitle       String?
  sessionDescription String?  @db.Text
  sessionType        String?
  fee                Decimal? @db.Decimal(10, 2)
  feeCurrency        String?  @default("GBP")
  feeStatus          String?  @default("Not Set")
  contractStatus     String?  @default("Not Started")
  travelRequired     Boolean  @default(false)
  hotelRequired      Boolean  @default(false)
  tags               String?
  notes              String?  @db.Text
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  activities Activity[]
}

// ─────────────────────────────────────────────────────────────────────────────
// SPONSORS — sponsoring companies / contacts
// ─────────────────────────────────────────────────────────────────────────────

model Sponsor {
  id                  String   @id @default(cuid())
  companyName         String
  website             String?
  // Primary contact
  contactFirstName    String?
  contactLastName     String?
  contactEmail        String?
  contactPhone        String?
  contactLinkedinUrl  String?
  contactJobTitle     String?
  country             String?
  city                String?
  // CRM fields
  tier                String?  @default("Bronze")
  status              String   @default("Prospecting")
  valueAmount         Decimal? @db.Decimal(12, 2)
  valueCurrency       String?  @default("GBP")
  contractStatus      String?  @default("Not Started")
  packageDetails      String?  @db.Text
  tags                String?
  notes               String?  @db.Text
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  activities Activity[]
}

// ─────────────────────────────────────────────────────────────────────────────
// STAGED CONTACTS — CSV import inbox, pending triage
// ─────────────────────────────────────────────────────────────────────────────

model StagedContact {
  id           String   @id @default(cuid())
  firstName    String?
  lastName     String?
  email        String?
  phone        String?
  linkedinUrl  String?
  organization String?
  jobTitle     String?
  country      String?
  city         String?
  bio          String?  @db.Text
  tags         String?
  notes        String?  @db.Text
  status       String   @default("pending")
  assignedAs   String?
  assignedId   String?
  importBatch  String?
  rawData      String?  @db.Text
  createdAt    DateTime @default(now())
}

// ─────────────────────────────────────────────────────────────────────────────
// ACTIVITIES — universal activity log / timeline
// ─────────────────────────────────────────────────────────────────────────────

model Activity {
  id          String   @id @default(cuid())
  // Polymorphic entity reference
  entityType  String   // "delegate" | "speaker" | "sponsor"
  delegateId  String?
  delegate    Delegate? @relation(fields: [delegateId], references: [id], onDelete: Cascade)
  speakerId   String?
  speaker     Speaker?  @relation(fields: [speakerId], references: [id], onDelete: Cascade)
  sponsorId   String?
  sponsor     Sponsor?  @relation(fields: [sponsorId], references: [id], onDelete: Cascade)
  // Activity data
  type        String   // "note" | "call" | "email" | "meeting" | "status_change" | "task"
  content     String   @db.Text
  metadata    String?  @db.Text  // JSON string for extra data (old/new status, etc.)
  createdBy   String?
  createdAt   DateTime @default(now())
}
