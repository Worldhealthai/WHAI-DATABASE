# Supabase (Project Settings → API in the Supabase dashboard)
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Shared secret for the website → CRM registration webhook.
# MUST be the exact same value as CRM_WEBHOOK_SECRET on the
# -world-health-ai (website) Vercel project, or forwarding fails with 401.
WEBHOOK_SECRET="generate-one-long-random-string-and-use-it-in-both-projects"

# Pulse AI assistant
ANTHROPIC_API_KEY="sk-ant-..."
